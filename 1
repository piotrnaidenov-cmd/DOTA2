-- Орбитальная аура (старая)
local orbitConnection
createToggle("🪐 Орбитальная Аура (Планеты)", function(state)
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    if state then
        local parts = {}
        for i = 1, 3 do
            local p = Instance.new("Part")
            p.Shape = Enum.PartType.Ball
            p.Size = Vector3.new(2, 2, 2)
            p.Anchored = true
            p.CanCollide = false
            p.Color = (i == 1) and Color3.new(0, 0, 0) or Color3.new(0.5, 0.5, 1)
            p.Parent = char
            table.insert(parts, p)
        end
        orbitConnection = RunService.RenderStepped:Connect(function()
            local time = tick()
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            for i, part in pairs(parts) do
                local angle = time * 2 + (i * 2)
                part.CFrame = root.CFrame * CFrame.new(math.cos(angle) * 8, 0, math.sin(angle) * 8)
            end
        end)
    else
        if orbitConnection then orbitConnection:Disconnect() end
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Part") and v.Shape == Enum.PartType.Ball then v:Destroy() end
        end
    end
end)

-- Новая планетарная система (Ад, Земля, Луна)
local planetSystemConnection = nil
local planetModels = {}
createToggle("🪐 Планетарная система (Ад, Земля, Луна)", function(state)
    if state then
        local function createPlanet(color, speed, offset, yMod)
            local model = Instance.new("Model", workspace)
            model.Name = "PlanetCore"
            
            local p = Instance.new("Part", model)
            p.Shape = Enum.PartType.Ball
            p.Size = Vector3.new(4, 4, 4)
            p.Color = color
            p.Material = Enum.Material.Neon
            p.Anchored = true
            p.CanCollide = false
            
            local ring = Instance.new("Part", model)
            ring.Shape = Enum.PartType.Cylinder
            ring.Size = Vector3.new(0.5, 6, 6)
            ring.Color = color
            ring.Material = Enum.Material.ForceField
            ring.Anchored = true
            ring.CanCollide = false
            ring.Transparency = 0.3
            
            return {Model = model, Part = p, Ring = ring, Speed = speed, Offset = offset, YMod = yMod}
        end
        
        local planets = {
            createPlanet(Color3.fromRGB(255, 50, 50), 2, 10, 0),
            createPlanet(Color3.fromRGB(0, 150, 255), 3, 7, 2),
            createPlanet(Color3.fromRGB(255, 255, 0), 5, 5, -2)
        }
        planetModels = planets
        
        planetSystemConnection = RunService.RenderStepped:Connect(function()
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            for _, pData in pairs(planets) do
                local t = tick() * pData.Speed
                local x = math.cos(t) * pData.Offset
                local z = math.sin(t) * pData.Offset
                local y = math.sin(t) * pData.YMod
                local pos = hrp.CFrame * CFrame.new(x, y, z)
                pData.Part.CFrame = pos * CFrame.Angles(t, t, 0)
                pData.Ring.CFrame = pos * CFrame.Angles(0, 0, 1.57)
            end
        end)
    else
        if planetSystemConnection then
            planetSystemConnection:Disconnect()
            planetSystemConnection = nil
        end
        for _, pData in pairs(planetModels) do
            if pData.Model then pData.Model:Destroy() end
        end
        planetModels = {}
        for _, v in pairs(workspace:GetChildren()) do
            if v.Name == "PlanetCore" then v:Destroy() end
        end
    end
end)

