local function createCC(name, sat, cont, tint)
    local cc = Instance.new("ColorCorrectionEffect", Lighting)
    cc.Name = name
    cc.Enabled = false
    cc.Saturation = sat or 0
    cc.Contrast = cont or 0
    if tint then cc.TintColor = tint end
    return cc
end

