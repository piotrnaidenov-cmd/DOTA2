-- === ФУНКЦИИ UI ===
local function createCategory(text)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -10, 0, 25)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(150, 150, 255)
    lbl.TextSize = 14
    lbl.Font = Enum.Font.GothamBlack
    lbl.Text = "— " .. text .. " —"
    lbl.LayoutOrder = layoutCounter
    lbl.Parent = Scroll
    layoutCounter = layoutCounter + 1
end

local function createToggle(text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = text .. " [ОФФ]"
    btn.AutoButtonColor = false
    btn.LayoutOrder = layoutCounter
    btn.Parent = Scroll
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    layoutCounter = layoutCounter + 1

    local enabled = false
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        local targetColor = enabled and Color3.fromRGB(60, 180, 90) or Color3.fromRGB(40, 40, 50)
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        btn.Text = text .. (enabled and " [ВКЛ]" or " [ОФФ]")
        pcall(function() callback(enabled) end)
    end)
end

-- === Утилита для удаления аур (по имени эмиттера) ===
local function removeAura(name)
